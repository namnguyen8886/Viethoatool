# ================================================
# CAU HINH HE THONG DICH v3.1.0
# Copy: cp .env.example .env
# ================================================

# Lay key tai: https://aistudio.google.com/app/apikey

# Mot key:
GEMINI_API_KEY=AIzaSy_YOUR_KEY_HERE

# Nhieu key (phan cach dau phay):
# GEMINI_API_KEYS=AIzaSy_KEY1,AIzaSy_KEY2,AIzaSy_KEY3


# Toggle nhanh de test module
USE_GEMINI=true
USE_GG=true
LEARN_FROM_GEMINI=true
SAVE_FAIL_ARTIFACTS=true
GG_WORKERS=8
GG_CHUNK_CHARS=1200
GG_REQUESTS_PER_SECOND=2.2
GG_RETRY_COUNT=2
GG_RETRY_BASE_SECONDS=1.25
GG_RETRY_MAX_SECONDS=8
GG_FRAGMENT_CACHE_SIZE=10000

GG_MIN_CONCURRENCY=2
GG_MAX_CONCURRENCY=6
GG_ENDPOINTS=https://translate.googleapis.com/translate_a/single,https://translate.google.com/translate_a/single,https://translate.google.com.vn/translate_a/single
GG_BACKEND_TIMEOUT_MS=2500
GG_BACKEND_MAX_FAIL=3
GG_BACKEND_COOLDOWN_SEC=60
